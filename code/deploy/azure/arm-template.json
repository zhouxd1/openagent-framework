{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "environmentName": {
      "type": "string",
      "defaultValue": "openagent-env",
      "metadata": {
        "description": "Name of the Container Apps environment"
      }
    },
    "appName": {
      "type": "string",
      "defaultValue": "openagent",
      "metadata": {
        "description": "Name of the container app"
      }
    },
    "dockerImage": {
      "type": "string",
      "defaultValue": "openagent/openagent:latest",
      "metadata": {
        "description": "Docker image for the application"
      }
    },
    "databaseUrl": {
      "type": "securestring",
      "metadata": {
        "description": "Database connection URL"
      }
    },
    "redisUrl": {
      "type": "securestring",
      "metadata": {
        "description": "Redis connection URL"
      }
    }
  },
  "variables": {
    "containerAppApiVersion": "2023-05-01"
  },
  "resources": [
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "[variables('containerAppApiVersion')]",
      "name": "[parameters('environmentName')]",
      "location": "[parameters('location')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', 'openagent-logs'), '2022-10-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', 'openagent-logs'), '2022-10-01').primarySharedKey]"
          }
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "[variables('containerAppApiVersion')]",
      "name": "[parameters('appName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('environmentName'))]"
      ],
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('environmentName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 3000,
            "transport": "auto"
          },
          "secrets": [
            {
              "name": "database-url",
              "value": "[parameters('databaseUrl')]"
            },
            {
              "name": "redis-url",
              "value": "[parameters('redisUrl')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "openagent",
              "image": "[parameters('dockerImage')]",
              "env": [
                {
                  "name": "NODE_ENV",
                  "value": "production"
                },
                {
                  "name": "LOG_LEVEL",
                  "value": "info"
                },
                {
                  "name": "PORT",
                  "value": "3000"
                },
                {
                  "name": "DATABASE_URL",
                  "secretRef": "database-url"
                },
                {
                  "name": "REDIS_URL",
                  "secretRef": "redis-url"
                }
              ],
              "resources": {
                "cpu": 0.5,
                "memory": "1Gi"
              }
            }
          ],
          "scale": {
            "minReplicas": 2,
            "maxReplicas": 10,
            "rules": [
              {
                "name": "cpu-scaling",
                "custom": {
                  "type": "cpu",
                  "metadata": {
                    "type": "Utilization",
                    "value": "80"
                  }
                }
              }
            ]
          }
        }
      }
    }
  ],
  "outputs": {
    "containerAppUrl": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('appName')), variables('containerAppApiVersion')).configuration.ingress.fqdn]"
    }
  }
}
