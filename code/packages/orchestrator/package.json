{
  "name": "@openagent/orchestrator",
  "version": "0.1.0",
  "description": "Agent orchestration framework for OpenAgent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test"
