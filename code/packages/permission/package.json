{
  "name": "@openagent/permission",
  "version": "0.1.0",
  "description": "Enterprise-grade permission system for OpenAgent Framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist node_modules",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "openid-client": "^5.6.0",
    "@node-saml/passport-saml": "^4.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "@vitest/coverage-v8": "^1.2.0",
    "prisma": "^5.22.0"
  },
  "keywords": [
    "permission",
    "rbac",
    "authorization",
    "security",
    "sso",
    "saml",
    "oidc",
    "audit"
  ],
  "author": "OpenAgent Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openagent/framework",
    "directory": "packages/permission"
  }
